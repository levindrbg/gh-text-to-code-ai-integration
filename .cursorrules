# JSON SCHEMA CONTRACT
## The canonical interface between exec()'d scripts and Grasshopper geometry builder
## All LLM-generated scripts MUST output JSON conforming to this structure

```json
{
  "metadata": {
    "typology": "gable_roof | hip_roof | flat_truss | cantilever",
    "span_m": 0.0,
    "height_m": 0.0,
    "iterations": 0,
    "timestamp": "ISO8601"
  },
  "nodes": [
    { "id": 0, "x": 0.0, "y": 0.0, "z": 0.0, "is_support": false }
  ],
  "members": [
    {
      "id": 0,
      "start_node": 0,
      "end_node": 1,
      "length_m": 0.0,
      "area_cm2": 0.0,
      "force_kN": 0.0,
      "stress_MPa": 0.0,
      "material": "steel | timber | cfrp",
      "section_type": "SHS | RHS | circular | rectangular",
      "width_mm": 0.0,
      "height_mm": 0.0
    }
  ],
  "loads": [
    { "node_id": 0, "Fx_kN": 0.0, "Fy_kN": 0.0, "Fz_kN": 0.0 }
  ],
  "results": {
    "max_displacement_mm": 0.0,
    "max_stress_MPa": 0.0,
    "total_volume_m3": 0.0,
    "converged": true
  }
}
```

