# API INTEGRATION PATTERNS
## Claude only — no OpenAI. All HTTP via urllib.request (no SDKs).

### Pinecone REST Query (rag_query.py pattern)
When using RAG, embed the user query with a non-OpenAI provider (e.g. Cohere, Voyage, or ingest via n8n). This project does not use OpenAI. Example: call your chosen embedding API via urllib, then POST the vector to Pinecone /query with Api-Key and Content-Type. Omit RAG entirely if you start with a fixed system prompt + code snippets.

### Claude (Anthropic) Messages API — llm_generate.py pattern
```python
import urllib.request, json, os

def generate_script(user_prompt: str, context_chunks: list[dict]) -> str:
    """
    Sends prompt + RAG context to Anthropic Claude API, returns generated Python script string.
    Claude only; no OpenAI.
    """
    API_KEY = os.environ.get("ANTHROPIC_API_KEY") or os.environ.get("CLAUDE_API_KEY")
    if not API_KEY:
        raise ValueError("Set ANTHROPIC_API_KEY or CLAUDE_API_KEY in .env")

    context_text = "\n\n---\n\n".join(c["text"] for c in context_chunks) if context_chunks else ""

    system_prompt = f"""You are a structural engineering code generator for Grasshopper/Karamba3D.
Your task: write a self-contained Python 3 script that generates a structural roof system.

KNOWLEDGE BASE CONTEXT (use this to ground your implementation):
{context_text}

OUTPUT RULES:
- Output ONLY executable Python 3 code, no markdown fences, no explanation
- The script must end by printing a single JSON string conforming to the structural_output schema
- Use only: numpy, scipy, json, math, os, sys (no matplotlib, no pandas)
- All units: meters for geometry, kN for forces, MPa for stress, cm² for cross-sections
- Include a main() function; call it at the end with: if __name__ == "__main__" or always
"""

    payload = json.dumps({
        "model": "claude-sonnet-4-20250514",
        "max_tokens": 8192,
        "system": system_prompt,
        "messages": [{"role": "user", "content": user_prompt}],
        "temperature": 0.2
    }).encode()

    req = urllib.request.Request(
        "https://api.anthropic.com/v1/messages",
        data=payload,
        headers={
            "x-api-key": API_KEY,
            "anthropic-version": "2023-06-01",
            "Content-Type": "application/json"
        }
    )
    with urllib.request.urlopen(req) as r:
        data = json.loads(r.read())
    # Response: content is list of blocks; first text block has .text
    for block in data.get("content", []):
        if block.get("type") == "text":
            return block["text"]
    raise ValueError("No text content in Claude response")
```

### Script Execution (script_executor.py pattern)
```python
import io, sys, json

def execute_generated_script(script_str: str) -> dict:
    """
    exec()'s the generated script, captures stdout, parses JSON output.
    Returns the parsed structural result dict, or raises on failure.
    """
    stdout_capture = io.StringIO()
    old_stdout = sys.stdout
    sys.stdout = stdout_capture

    exec_globals = {}
    try:
        exec(compile(script_str, "<llm_generated>", "exec"), exec_globals)
    finally:
        sys.stdout = old_stdout

    output = stdout_capture.getvalue().strip()

    # Find the last JSON object in stdout (script may print debug before final JSON)
    for line in reversed(output.splitlines()):
        line = line.strip()
        if line.startswith("{") and line.endswith("}"):
            return json.loads(line)

    raise ValueError(f"No valid JSON found in script output. Got:\n{output}")
```

