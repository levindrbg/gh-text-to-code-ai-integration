# GHPython DYNAMIC LOADING PATTERN
## Use in GH Python components (02_grasshopper). Scripts live in 03_python.

```python
# Paste into GHPython component (CPython 3 mode in Rhino 8 ScriptEditor)
import os, sys

REPO_ROOT = r"C:\path\to\repo"  # set once per machine; or from GH panel input
SCRIPTS_DIR = os.path.join(REPO_ROOT, "03_python")

if SCRIPTS_DIR not in sys.path:
    sys.path.insert(0, SCRIPTS_DIR)

# Load .env from repo root (03_python/config/settings.py)
config_path = os.path.join(REPO_ROOT, "03_python", "config", "settings.py")
exec(open(config_path).read())

# Run the target script; pass GH inputs via context
script_path = os.path.join(SCRIPTS_DIR, "rag_query.py")
ctx = {"ghenv": ghenv, "user_prompt": x}
exec(open(script_path).read(), ctx)
a = ctx.get("result")
```

