{
  "description": "JSON returned by gen script (hardcoded output) for Karamba/GH import.",
  "required": ["line_elements", "support", "loads", "load_points"],
  "properties": {
    "line_elements": {
      "type": "array",
      "description": "All lines: top chord, bottom chord, diagonals.",
      "items": {
        "type": "object",
        "properties": {
          "start": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
          "end": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 }
        }
      }
    },
    "support": {
      "type": "array",
      "description": "Support points: coordinates and type.",
      "items": {
        "type": "object",
        "properties": {
          "point": { "type": "array", "items": { "type": "number" } },
          "type": { "enum": ["pinned", "fixed", "roller"] }
        }
      }
    },
    "loads": {
      "type": "array",
      "description": "Load force at each load point (kN).",
      "items": {
        "type": "object",
        "properties": {
          "point": { "type": "array", "items": { "type": "number" } },
          "Fx_kN": { "type": "number" },
          "Fy_kN": { "type": "number" },
          "Fz_kN": { "type": "number" }
        }
      }
    },
    "load_points": {
      "type": "array",
      "description": "Nodes where lines meet and forces are applied. List of [x, y, z].",
      "items": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 }
    }
  }
}
