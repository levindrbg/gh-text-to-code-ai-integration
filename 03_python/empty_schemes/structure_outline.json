{
  "description": "Truss semantic outline — form to fill from user prompt (Interpreter).",
  "required": ["typology", "span_m", "height_m", "material"],
  "properties": {
    "typology": {
      "enum": ["gable_roof", "hip_roof", "flat_truss", "cantilever", "shed_roof", "mansard_roof"],
      "description": "Truss/roof typology"
    },
    "span_m": { "type": "number", "minimum": 0.1, "description": "Span in meters" },
    "height_m": { "type": "number", "minimum": 0.1, "description": "Height/rise in meters" },
    "material": {
      "enum": ["steel", "timber", "cfrp", "aluminum"],
      "description": "Primary structural material"
    },
    "loads": {
      "type": "object",
      "properties": {
        "snow_kN_per_m2": { "type": "number", "minimum": 0 },
        "wind_kN_per_m2": { "type": "number", "minimum": 0 },
        "dead_load_kN_per_m2": { "type": "number", "minimum": 0 }
      }
    },
    "supports": {
      "type": "object",
      "properties": {
        "type": { "enum": ["pinned", "fixed", "roller"] },
        "at_ridge": { "type": "boolean" }
      }
    },
    "geometry": {
      "type": "object",
      "properties": {
        "num_bays": { "type": "integer", "minimum": 1 },
        "longitudinal_length_m": { "type": "number", "minimum": 0.1 },
        "rafter_spacing_m": { "type": "number", "minimum": 0.5 }
      }
    },
    "notes": { "type": "string" }
  }
}
