{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Structured prompt schema — parsed from user's natural language input",
  "type": "object",
  "required": ["typology", "span_m", "height_m", "material"],
  "properties": {
    "typology": {
      "enum": ["gable_roof", "hip_roof", "flat_truss", "cantilever", "shed_roof", "mansard_roof"],
      "description": "Roof typology"
    },
    "span_m": {
      "type": "number",
      "minimum": 0.1,
      "description": "Span in meters (main direction)"
    },
    "height_m": {
      "type": "number",
      "minimum": 0.1,
      "description": "Height/rise in meters"
    },
    "material": {
      "enum": ["steel", "timber", "cfrp", "aluminum"],
      "description": "Primary structural material"
    },
    "loads": {
      "type": "object",
      "properties": {
        "snow_kN_per_m2": {
          "type": "number",
          "minimum": 0,
          "default": 1.0,
          "description": "Snow load in kN/m²"
        },
        "wind_kN_per_m2": {
          "type": "number",
          "minimum": 0,
          "default": 0.5,
          "description": "Wind load in kN/m²"
        },
        "dead_load_kN_per_m2": {
          "type": "number",
          "minimum": 0,
          "default": 0.5,
          "description": "Dead load (self-weight + cladding) in kN/m²"
        }
      }
    },
    "supports": {
      "type": "object",
      "properties": {
        "type": {
          "enum": ["pinned", "fixed", "roller"],
          "default": "pinned",
          "description": "Support type at wall plates"
        },
        "at_ridge": {
          "type": "boolean",
          "default": false,
          "description": "Whether ridge is supported"
        }
      }
    },
    "geometry": {
      "type": "object",
      "properties": {
        "num_bays": {
          "type": "integer",
          "minimum": 1,
          "default": 4,
          "description": "Number of bays along span"
        },
        "longitudinal_length_m": {
          "type": "number",
          "minimum": 0.1,
          "description": "Length perpendicular to span (if not specified, assume 1 bay)"
        },
        "rafter_spacing_m": {
          "type": "number",
          "minimum": 0.5,
          "default": 2.0,
          "description": "Spacing between rafters along longitudinal direction"
        }
      }
    },
    "notes": {
      "type": "string",
      "description": "Additional notes or constraints from the original prompt"
    }
  }
}
