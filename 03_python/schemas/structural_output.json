{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Canonical JSON contract between exec'd script and Grasshopper geometry builder",
  "type": "object",
  "required": ["metadata", "nodes", "members", "loads", "results"],
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "typology": { "enum": ["gable_roof", "hip_roof", "flat_truss", "cantilever"] },
        "span_m": { "type": "number" },
        "height_m": { "type": "number" },
        "iterations": { "type": "integer" },
        "timestamp": { "type": "string" }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "x", "y", "z", "is_support"],
        "properties": {
          "id": { "type": "integer" },
          "x": { "type": "number" },
          "y": { "type": "number" },
          "z": { "type": "number" },
          "is_support": { "type": "boolean" }
        }
      }
    },
    "members": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "start_node": { "type": "integer" },
          "end_node": { "type": "integer" },
          "length_m": { "type": "number" },
          "area_cm2": { "type": "number" },
          "force_kN": { "type": "number" },
          "stress_MPa": { "type": "number" },
          "material": { "type": "string" },
          "section_type": { "type": "string" },
          "width_mm": { "type": "number" },
          "height_mm": { "type": "number" }
        }
      }
    },
    "loads": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "node_id": { "type": "integer" },
          "Fx_kN": { "type": "number" },
          "Fy_kN": { "type": "number" },
          "Fz_kN": { "type": "number" }
        }
      }
    },
    "results": {
      "type": "object",
      "properties": {
        "max_displacement_mm": { "type": "number" },
        "max_stress_MPa": { "type": "number" },
        "total_volume_m3": { "type": "number" },
        "converged": { "type": "boolean" }
      }
    }
  }
}
